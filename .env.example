# CodeInsight Environment Configuration
# Copy this file to .env and fill in your values.

# === Required for AI Features ===
# OpenAI API key for embeddings and Q&A (optional if using Ollama)
CODEINSIGHT_OPENAI_API_KEY=

# === Optional: GitHub Integration ===
# GitHub token for cloning private repos
CODEINSIGHT_GITHUB_TOKEN=

# === Optional: Embedding Provider ===
# Choose: "openai" (default) or "ollama" for local embeddings
CODEINSIGHT_EMBEDDING_PROVIDER=openai
# CODEINSIGHT_EMBEDDING_MODEL=text-embedding-3-small
# CODEINSIGHT_EMBEDDING_BATCH_SIZE=64
# CODEINSIGHT_OLLAMA_BASE_URL=http://localhost:11434
# CODEINSIGHT_OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# === Optional: Parser ===
# Choose: "safe" (default, regex-based) or "tree_sitter" (requires tree-sitter)
CODEINSIGHT_PARSER_PROVIDER=safe

# === Optional: LLM Provider ===
# Choose: "ollama" (default, local), "groq" (production, free tier), or "none"
CODEINSIGHT_LLM_PROVIDER=ollama
# CODEINSIGHT_GROQ_API_KEY=gsk_...
# CODEINSIGHT_OLLAMA_CHAT_MODEL=llama3.2
# CODEINSIGHT_GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# === Optional: Database Paths ===
# CODEINSIGHT_CONVERSATION_DATABASE_PATH=data/conversations/codeinsight-conversations.sqlite3
# CODEINSIGHT_GRAPH_DATABASE_PATH=data/graphs/codeinsight-graph.sqlite3
# CODEINSIGHT_METADATA_DATABASE_PATH=data/codeinsight.sqlite3
# CODEINSIGHT_VECTOR_DATABASE_PATH=data/vectors/codeinsight-vectors.sqlite3
# CODEINSIGHT_REPOSITORY_STORAGE_PATH=data/repositories

# === Optional: Neo4j (if using graph database) ===
# CODEINSIGHT_NEO4J_URI=bolt://localhost:7687
# CODEINSIGHT_NEO4J_USERNAME=neo4j
# CODEINSIGHT_NEO4J_PASSWORD=codeinsight-dev
# CODEINSIGHT_NEO4J_DATABASE=neo4j

# === Optional: CORS ===
# Comma-separated origins for CORS (empty = localhost only)
# CODEINSIGHT_CORS_ORIGINS=

# === Optional: Server ===
# CODEINSIGHT_ENVIRONMENT=development
# CODEINSIGHT_LOG_LEVEL=INFO
